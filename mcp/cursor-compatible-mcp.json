{
  "mcpServers": {
    "context7": {
      "command": "bunx",
      "args": [
        "@upstash/context7-mcp"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "fs-projects": {
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-filesystem",
        "${env:DEV_PROJECTS_DIR}",
        "${env:OBSIDIAN_VAULT_DIR}",
        "${env:OBSIDIAN_BUSINESS_VAULT_DIR}",
        "${env:DEV_TOOLS_DIR}"
      ]
    },
    "cms": {
      "command": "bun",
      "args": [
        "${env:CMS_MCP_ENTRY}"
      ],
      "env": {
        "CMS_URL": "${env:CMS_URL}",
        "CMS_API_KEY": "${env:CMS_API_KEY}"
      }
    },
    "stitch": {
      "command": "bunx",
      "args": [
        "@_davideast/stitch-mcp",
        "proxy"
      ],
      "env": {
        "STITCH_API_KEY": "${env:STITCH_API_KEY}"
      }
    }
  }
}
